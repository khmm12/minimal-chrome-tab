    "browserslist-to-esbuild": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-config-love": "^154.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
