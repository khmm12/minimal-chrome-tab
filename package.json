    "remeda": "^2.39.0",
    "solid-js": "2.0.0-beta.15",
    "type-fest": "^5.7.0",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.11.4",
    "@pandacss/types": "^1.11.4",
    "@solidjs/testing-library": "file:vendor/solidjs-testing-library-1.0.0-beta.1-next-b7e188c.tgz",
