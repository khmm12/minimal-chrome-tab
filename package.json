  "license": "MIT",
  "type": "module",
  "engine": {
    "node": "^22 || ^24"
  },
  "scripts": {
    "prepare": "panda codegen --clean",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "run-p --aggregate-output lint typecheck:* test:*",
    "test:unit": "vitest --run --silent",
    "typecheck": "run-p --aggregate-output typecheck:*",
    "typecheck:app": "tsc --noEmit --pretty --project tsconfig.app.json",
    "typecheck:node": "tsc --noEmit --pretty --project tsconfig.node.json"
  },
  "sideEffects": [
    "src/index.tsx",
    "src/boot/**",
    "src/components/GlobalStyles/**",
    "*.css"
  ],
  "dependencies": {
    "@solidjs/web": "2.0.0-beta.10",
    "@total-typescript/ts-reset": "^0.6.1",
    "date-fns": "^4.1.0",
    "focus-trap": "^8.2.0",
    "remeda": "^2.34.0",
    "solid-js": "2.0.0-beta.10",
    "type-fest": "^5.6.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.11.0",
    "@pandacss/types": "^1.11.0",
    "@solidjs/testing-library": "file:vendor/solidjs-testing-library-1.0.0-beta.1-next-b7e188c.tgz",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
