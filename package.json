{
  "name": "minimal-chrome-tab",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "engine": {
    "node": "^22 || ^24"
  },
  "scripts": {
    "prepare": "panda codegen --clean",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "run-p --aggregate-output lint typecheck:* test:*",
    "test:unit": "vitest --run --silent",
    "typecheck": "run-p --aggregate-output typecheck:*",
    "typecheck:app": "tsc --noEmit --pretty --project tsconfig.app.json",
    "typecheck:node": "tsc --noEmit --pretty --project tsconfig.node.json"
  },
  "sideEffects": [
    "src/index.tsx",
    "src/boot/**",
    "src/components/GlobalStyles/**",
    "*.css"
  ],
  "dependencies": {
    "@tanstack/solid-form": "^1.28.3",
    "@total-typescript/ts-reset": "^0.6.1",
    "date-fns": "^4.1.0",
    "focus-trap": "^8.0.0",
    "remeda": "^2.33.6",
    "solid-js": "^1.9.11",
    "type-fest": "^5.4.4",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.8.2",
    "@pandacss/types": "^1.8.2",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/recommended": "^1.0.13",
    "@tsconfig/strictest": "^2.0.8",
    "@types/chrome": "^0.1.37",
    "@types/node": "^22.19.13",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "browserslist": "^4.28.1",
    "browserslist-to-esbuild": "^2.1.1",
    "eslint": "^9.39.3",
    "eslint-config-love": "^151.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.3",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "solid-devtools": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-solid": "^2.11.10",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
