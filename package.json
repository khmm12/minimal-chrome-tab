    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "browserslist": "^4.28.2",
    "browserslist-to-esbuild": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-config-love": "^153.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.14",
